#!/bin/bash
set -euo pipefail
export WT_ACTIVE=1
trap 'rm -f /tmp/wt-*.lock 2>/dev/null' EXIT

# ── Global state (set by resolve_project) ──
PROJECT_NAME=""
PROJECT_DIR=""
REPOS=()

# ── Config ──────────────────────────────────────────────
VERSION="1.0.0"

load_config() {
  local cfg="$HOME/.wtconfig"
  if [ ! -f "$cfg" ]; then
    cat > "$cfg" << 'EOF'
# wt 多仓库 worktree 管理器配置
WT_ROOT=$HOME/wt
EOF
    echo "✅ 已创建默认配置 $cfg"
  fi
  source "$cfg"
  [ -n "${WT_ROOT:-}" ] || { echo "❌ WT_ROOT 未配置"; exit 1; }
}

base_branch() {
  local repo=$1
  git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|refs/remotes/origin/||' || echo "main"
}

# ── Project resolution ─────────────────────────────────
# .wtrepos 文件格式：每行一个仓库绝对路径，# 开头为注释，空行跳过
resolve_project() {
  local dir="${PROJECT_FLAG:-}"
  if [ -z "$dir" ]; then
    dir="$PWD"
    while [ "$dir" != "/" ]; do
      [ -f "$dir/.wtrepos" ] && break
      dir="$(dirname "$dir")"
    done
    [ "$dir" = "/" ] && { echo "❌ 未找到 .wtrepos，请在项目目录内执行或用 -p <项目目录> 指定"; exit 1; }
  fi
  dir="$(cd "$dir" && pwd -P)"

  PROJECT_DIR="$dir"
  PROJECT_NAME="$(basename "$dir")"

  REPOS=()
  while IFS= read -r raw || [ -n "$raw" ]; do
    line="$(echo "$raw" | sed 's/#.*//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
    [ -z "$line" ] && continue
    [ -d "$line/.git" ] || { echo "❌ 仓库不存在或不是 git 仓库: $line"; exit 1; }
    REPOS+=("$(basename "$line")	$line")
  done < "$dir/.wtrepos"
  [ ${#REPOS[@]} -gt 0 ] || { echo "❌ $dir/.wtrepos 为空"; exit 1; }
}

worktree_path() { echo "$WT_ROOT/$PROJECT_NAME/$1"; }

# ── Context file ────────────────────────────────────────
context_write() {
  local name=$1 desc=${2:-}
  cat > "$(worktree_path "$name")/CONTEXT.md" <<-EOF
# 任务: $name
- 项目: $PROJECT_NAME
- 创建时间: $(date +%Y-%m-%d)
EOF
  for entry in "${REPOS[@]}"; do
    local label="${entry%%	*}"
    echo "- $label: ./$label → 分支 $name" >> "$(worktree_path "$name")/CONTEXT.md"
  done
  [ -z "$desc" ] || echo "- 描述: $desc" >> "$(worktree_path "$name")/CONTEXT.md"
}

# ── Helpers ──────────────────────────────────────────────
repo_status() {
  local project=$1 name=$2 repo=$3
  local dir="$WT_ROOT/$project/$name/$(basename "$repo")"
  [ -d "$dir" ] || { echo "missing"; return; }
  local branch
  branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")
  if [ "$branch" = "detached" ]; then echo "detached"; return; fi
  local base
  base=$(base_branch "$repo")
  git -C "$dir" diff --quiet 2>/dev/null || { echo "dirty"; return; }
  local behind
  behind=$(git -C "$dir" rev-list "HEAD..origin/$base" --count 2>/dev/null || echo 0)
  local ahead
  ahead=$(git -C "$dir" rev-list "origin/$base..HEAD" --count 2>/dev/null || echo 0)
  if [ "$ahead" -gt 0 ] && [ "$behind" -eq 0 ]; then echo "ahead"; return; fi
  if [ "$behind" -gt 0 ]; then echo "behind"; return; fi
  git -C "$dir" branch --merged "origin/$base" 2>/dev/null | grep -q "^\*\| $branch$" \
    && { echo "merged"; return; }
  echo "clean"
}

# ── Commands ─────────────────────────────────────────────
cmd_create() {
  local name=$1 desc=${2:-}
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] && { echo "❌ 任务 $name 已存在: $dir"; exit 1; }
  mkdir -p "$dir"
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    git -C "$repo" worktree add "$dir/$label" -b "$name" "$(base_branch "$repo")" 2>&1 \
      | sed "s/^/   $label: /"
  done
  context_write "$name" "$desc"
  echo "✅ 任务 $name 已创建"
  local first="${REPOS[0]%%	*}"
  echo "   cd $dir/$first"
}

cmd_list() {
  local root="$WT_ROOT"
  [ -d "$root" ] || { echo "暂无任务"; return; }
  local any=false
  for pdir in "$root"/*/; do
    [ ! -d "$pdir" ] && continue
    local project
    project="$(basename "$pdir")"
    echo "─── $project ───"
    for tdir in "$pdir"/*/; do
      [ ! -d "$tdir" ] && continue
      local name ctime
      name="$(basename "$tdir")"
      ctime=$(head -3 "$tdir/CONTEXT.md" 2>/dev/null | grep "创建时间" | sed 's/.*: //')
      ctime=${ctime:-"-"}
      echo "  $name  ($ctime)"
      any=true
    done
  done
  $any || echo "暂无任务"
}

cmd_status() {
  local name=$1
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "❌ 任务 $name 不存在"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    echo "─── $label ───"
    local wd="$dir/$label"
    if [ ! -d "$wd" ]; then
      echo "   worktree 不存在"
    else
      git -C "$wd" status --short 2>/dev/null | sed 's/^/  /'
      local ahead behind base
      base=$(base_branch "$repo")
      behind=$(git -C "$wd" rev-list "HEAD..origin/$base" --count 2>/dev/null || echo 0)
      ahead=$(git -C "$wd" rev-list "origin/$base..HEAD" --count 2>/dev/null || echo 0)
      echo "   分支: $(git -C "$wd" rev-parse --abbrev-ref HEAD)  |  落后: $behind  领先: $ahead"
    fi
  done
}

cmd_commit() {
  local name=$1 msg=$2; shift 2
  local no_push=false amend=false
  for arg in "$@"; do
    [ "$arg" = "--no-push" ] && no_push=true
    [ "$arg" = "--amend" ] && amend=true
  done
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "❌ 任务 $name 不存在"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "⚠️  $label worktree 不存在，跳过"; continue; }
    local has_changes
    has_changes=$(cd "$wd" && git status --porcelain 2>/dev/null | head -1)
    [ -z "$has_changes" ] && { echo "ℹ️  $label 无改动，跳过"; continue; }
    local amend_flag=""
    $amend && amend_flag="--amend"
    (cd "$wd" && git add . && git commit ${amend_flag:+"$amend_flag"} -m "$msg") 2>&1 | sed "s/^/   $label: /"
    if ! $no_push; then
      (cd "$wd" && git push origin "$(git rev-parse --abbrev-ref HEAD)") 2>&1 \
        | sed "s/^/   $label push: /" || echo "⚠️  $label push 失败"
    fi
  done
  echo "✅ 提交完成"
}

cmd_rebase() {
  local name=$1
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "❌ 任务 $name 不存在"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "⚠️  $label worktree 不存在，跳过"; continue; }
    local base
    base=$(base_branch "$repo")
    (cd "$wd" \
      && git stash push -m "wt-auto-$(date +%s)" 2>/dev/null || true \
      && git fetch origin 2>&1 \
      && git rebase "origin/$base" 2>&1 \
      && git stash pop 2>/dev/null || true) | sed "s/^/   $label: /" || {
        echo "❌ $label rebase 冲突，请手动处理"; exit 1
      }
  done
  echo "✅ rebase 完成"
}

cmd_cleanup() {
  local name=$1; shift
  local force=false
  for arg in "$@"; do [ "$arg" = "--force" ] && force=true; done
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "❌ 任务 $name 不存在"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "⚠️  $label worktree 不存在，跳过"; continue; }
    if ! $force; then
      local branch
      branch=$(git -C "$wd" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
      local base
      base=$(base_branch "$repo")
      local merged
      merged=$(git -C "$repo" branch --merged "origin/$base" 2>/dev/null \
        | grep -q "^\*\| $branch$" && echo true || echo false)
      local pushed
      pushed=$(git -C "$wd" rev-list "origin/$branch..HEAD" --count 2>/dev/null || echo 1)
      [ "$merged" != "true" ] && { echo "❌ $label 分支未合并，用 --force 跳过检查"; exit 1; }
      [ "$pushed" -gt 0 ] && { echo "❌ $label 有未推送提交，用 --force 跳过检查"; exit 1; }
    fi
    git -C "$repo" worktree remove "$wd" 2>&1 | sed "s/^/   $label: /" || {
      echo "⚠️  $label worktree remove 失败，尝试 git branch -D"
      local branch
      branch=$(git -C "$wd" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
      [ -n "$branch" ] && git -C "$repo" branch -D "$branch" 2>/dev/null || true
    }
  done
  rm -f "$dir/CONTEXT.md"
  rmdir "$dir" 2>/dev/null || echo "⚠️  目录 $dir 未完全清空，请手动检查"
  echo "✅ 清理完成"
}

cmd_doctor() {
  local root="$WT_ROOT"
  [ -d "$root" ] || { echo "✅ 无残留任务"; return; }
  local found=false
  for pdir in "$root"/*/; do
    [ ! -d "$pdir" ] && continue
    local project
    project="$(basename "$pdir")"
    for tdir in "$pdir"/*/; do
      [ ! -d "$tdir" ] && continue
      local name
      name="$(basename "$tdir")"
      local issues=()
      [ ! -f "$tdir/CONTEXT.md" ] && issues+=("缺 CONTEXT.md")
      if [ ${#issues[@]} -gt 0 ]; then
        found=true
        echo "─── $project / $name ───"
        for i in "${issues[@]}"; do echo "   ⚠️  $i"; done
      fi
    done
  done
  $found || echo "✅ 无异常"
}

cmd_update() {
  local self
  self=$(type -p wt 2>/dev/null || echo "$0")
  if [ -L "$self" ]; then
    local link_target="$self"
    local link_parent
    while [ -L "$link_target" ]; do
      link_parent=$(dirname "$link_target")
      link_target=$(readlink "$link_target" 2>/dev/null || true)
      [ -z "$link_target" ] && break
      case "$link_target" in
        /*) ;;
        *) link_target="$link_parent/$link_target" ;;
      esac
    done
    if echo "$link_target" | grep -q node_modules; then
      echo "❌ 通过 npm 安装，请用 npm update -g wt-multi-repo 更新" >&2
      exit 1
    fi
  fi
  local target="$self"
  local latest
  latest=$(git ls-remote --tags https://gitee.com/cybxcoder/wt.git 2>/dev/null \
    | sed 's/.*refs\/tags\///' | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | tail -1)
  local tag="${latest:-master}"
  local url="https://gitee.com/cybxcoder/wt/raw/${tag}/wt"
  curl -fsSL "$url" -o "$target.tmp" && chmod +x "$target.tmp" && mv "$target.tmp" "$target"
  echo "✅ wt 已更新到 ${tag}"
}

# ── Dispatch ─────────────────────────────────────────────
usage() {
  echo "用法: wt [-p <项目目录>] <命令> [参数]"
  echo ""
  echo "命令:"
  echo "  create <name> [-m <描述>]   创建跨仓库 worktree"
  echo "  list                         列出活跃任务"
  echo "  status <name>                查看仓库状态"
  echo "  commit <name> <msg> [选项]   提交+推送"
  echo "                               选项: --no-push, --amend"
  echo "  rebase <name>                仓库 rebase 主分支"
  echo "  cleanup <name> [--force]     清理 worktree"
  echo "  doctor                       检查残留 worktree"
  echo "  update                       更新 wt 到最新版"
  echo ""
  echo "示例:"
  echo "  cd ~/projects/UMES3 && wt create fix-login"
  echo "  wt -p ~/projects/CeLiangBen status fix-order"
}

load_config

# Parse -p global option
PROJECT_FLAG=""
if [ $# -ge 2 ] && [ "$1" = "-p" ]; then
  PROJECT_FLAG="$2"
  shift 2
fi

[ "${1:-}" = "--version" ] && { echo "wt $VERSION"; exit 0; }
[ $# -lt 1 ] && { usage; exit 1; }

case "${1:-}" in
  create)
    name="${2:-}"; [ -z "$name" ] && { echo "需要任务名"; exit 1; }
    desc=""; [ "${3:-}" = "-m" ] && desc="${4:-}"
    cmd_create "$name" "$desc"
    ;;
  list) cmd_list ;;
  status)
    name="${2:-}"; [ -z "$name" ] && { echo "需要任务名"; exit 1; }
    cmd_status "$name"
    ;;
  commit)
    name="${2:-}"; msg="${3:-}"
    [ -z "$name" ] && { echo "需要任务名"; exit 1; }
    [ -z "$msg" ] && { echo "需要提交信息"; exit 1; }
    shift 3; cmd_commit "$name" "$msg" "$@"
    ;;
  rebase)
    name="${2:-}"; [ -z "$name" ] && { echo "需要任务名"; exit 1; }
    cmd_rebase "$name"
    ;;
  cleanup)
    name="${2:-}"; [ -z "$name" ] && { echo "需要任务名"; exit 1; }
    shift 2; cmd_cleanup "$name" "$@"
    ;;
  doctor) cmd_doctor ;;
  update) cmd_update ;;
  *) usage; exit 1 ;;
esac

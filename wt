#!/bin/bash
set -euo pipefail
export WT_ACTIVE=1
trap 'rm -f /tmp/wt-*.lock 2>/dev/null' EXIT

# в”Җв”Җ Global state (set by resolve_project) в”Җв”Җ
PROJECT_NAME=""
PROJECT_DIR=""
REPOS=()

# в”Җв”Җ Config в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
VERSION="1.0.2"

load_config() {
  local cfg="$HOME/.wtconfig"
  if [ ! -f "$cfg" ]; then
    cat > "$cfg" << 'EOF'
# wt еӨҡд»“еә“ worktree з®ЎзҗҶеҷЁй…ҚзҪ®
WT_ROOT=$HOME/wt
EOF
    echo "вң… е·ІеҲӣе»әй»ҳи®Өй…ҚзҪ® $cfg"
  fi
  source "$cfg"
  [ -n "${WT_ROOT:-}" ] || { echo "вқҢ WT_ROOT жңӘй…ҚзҪ®"; exit 1; }
}

base_branch() {
  local repo=$1
  git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's|refs/remotes/origin/||' || echo "main"
}

# в”Җв”Җ Project resolution в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# .wtrepos ж–Үд»¶ж јејҸпјҡжҜҸиЎҢдёҖдёӘд»“еә“з»қеҜ№и·Ҝеҫ„пјҢ# ејҖеӨҙдёәжіЁйҮҠпјҢз©әиЎҢи·іиҝҮ
resolve_project() {
  local dir="${PROJECT_FLAG:-}"
  if [ -z "$dir" ]; then
    dir="$PWD"
    while [ "$dir" != "/" ]; do
      [ -f "$dir/.wtrepos" ] && break
      dir="$(dirname "$dir")"
    done
    [ "$dir" = "/" ] && { echo "вқҢ жңӘжүҫеҲ° .wtreposпјҢиҜ·еңЁйЎ№зӣ®зӣ®еҪ•еҶ…жү§иЎҢжҲ–з”Ё -p <йЎ№зӣ®зӣ®еҪ•> жҢҮе®ҡ"; exit 1; }
  fi
  dir="$(cd "$dir" && pwd -P)"

  PROJECT_DIR="$dir"
  PROJECT_NAME="$(basename "$dir")"

  REPOS=()
  while IFS= read -r raw || [ -n "$raw" ]; do
    line="$(echo "$raw" | sed 's/#.*//; s/^[[:space:]]*//; s/[[:space:]]*$//')"
    [ -z "$line" ] && continue
    [ -d "$line/.git" ] || { echo "вқҢ д»“еә“дёҚеӯҳеңЁжҲ–дёҚжҳҜ git д»“еә“: $line"; exit 1; }
    REPOS+=("$(basename "$line")	$line")
  done < "$dir/.wtrepos"
  [ ${#REPOS[@]} -gt 0 ] || { echo "вқҢ $dir/.wtrepos дёәз©ә"; exit 1; }
}

worktree_path() { echo "$WT_ROOT/$PROJECT_NAME/$1"; }

# в”Җв”Җ Context file в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
context_write() {
  local name=$1 desc=${2:-}
  cat > "$(worktree_path "$name")/CONTEXT.md" <<-EOF
# д»»еҠЎ: $name
- йЎ№зӣ®: $PROJECT_NAME
- еҲӣе»әж—¶й—ҙ: $(date +%Y-%m-%d)
EOF
  for entry in "${REPOS[@]}"; do
    local label="${entry%%	*}"
    echo "- $label: ./$label вҶ’ еҲҶж”Ҝ $name" >> "$(worktree_path "$name")/CONTEXT.md"
  done
  [ -z "$desc" ] || echo "- жҸҸиҝ°: $desc" >> "$(worktree_path "$name")/CONTEXT.md"
}

# в”Җв”Җ Helpers в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
repo_status() {
  local project=$1 name=$2 repo=$3
  local dir="$WT_ROOT/$project/$name/$(basename "$repo")"
  [ -d "$dir" ] || { echo "missing"; return; }
  local branch
  branch=$(git -C "$dir" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "detached")
  if [ "$branch" = "detached" ]; then echo "detached"; return; fi
  local base
  base=$(base_branch "$repo")
  git -C "$dir" diff --quiet 2>/dev/null || { echo "dirty"; return; }
  local behind
  behind=$(git -C "$dir" rev-list "HEAD..origin/$base" --count 2>/dev/null || echo 0)
  local ahead
  ahead=$(git -C "$dir" rev-list "origin/$base..HEAD" --count 2>/dev/null || echo 0)
  if [ "$ahead" -gt 0 ] && [ "$behind" -eq 0 ]; then echo "ahead"; return; fi
  if [ "$behind" -gt 0 ]; then echo "behind"; return; fi
  git -C "$dir" branch --merged "origin/$base" 2>/dev/null | grep -q "^\*\| $branch$" \
    && { echo "merged"; return; }
  echo "clean"
}

# в”Җв”Җ Commands в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
cmd_create() {
  local name=$1 desc=${2:-}
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] && { echo "вқҢ д»»еҠЎ $name е·ІеӯҳеңЁ: $dir"; exit 1; }
  mkdir -p "$dir"
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    git -C "$repo" worktree add "$dir/$label" -b "$name" "$(base_branch "$repo")" 2>&1 \
      | sed "s/^/   $label: /"
  done
  context_write "$name" "$desc"
  echo "вң… д»»еҠЎ $name е·ІеҲӣе»ә"
  local first="${REPOS[0]%%	*}"
  echo "   cd $dir/$first"
}

cmd_list() {
  local root="$WT_ROOT"
  [ -d "$root" ] || { echo "жҡӮж— д»»еҠЎ"; return; }
  local any=false
  for pdir in "$root"/*/; do
    [ ! -d "$pdir" ] && continue
    local project
    project="$(basename "$pdir")"
    echo "в”Җв”Җв”Җ $project в”Җв”Җв”Җ"
    for tdir in "$pdir"/*/; do
      [ ! -d "$tdir" ] && continue
      local name ctime
      name="$(basename "$tdir")"
      ctime=$(head -3 "$tdir/CONTEXT.md" 2>/dev/null | grep "еҲӣе»әж—¶й—ҙ" | sed 's/.*: //')
      ctime=${ctime:-"-"}
      echo "  $name  ($ctime)"
      any=true
    done
  done
  $any || echo "жҡӮж— д»»еҠЎ"
}

cmd_status() {
  local name=$1
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "вқҢ д»»еҠЎ $name дёҚеӯҳеңЁ"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    echo "в”Җв”Җв”Җ $label в”Җв”Җв”Җ"
    local wd="$dir/$label"
    if [ ! -d "$wd" ]; then
      echo "   worktree дёҚеӯҳеңЁ"
    else
      git -C "$wd" status --short 2>/dev/null | sed 's/^/  /'
      local ahead behind base
      base=$(base_branch "$repo")
      behind=$(git -C "$wd" rev-list "HEAD..origin/$base" --count 2>/dev/null || echo 0)
      ahead=$(git -C "$wd" rev-list "origin/$base..HEAD" --count 2>/dev/null || echo 0)
      echo "   еҲҶж”Ҝ: $(git -C "$wd" rev-parse --abbrev-ref HEAD)  |  иҗҪеҗҺ: $behind  йўҶе…Ҳ: $ahead"
    fi
  done
}

cmd_commit() {
  local name=$1 msg=$2; shift 2
  local no_push=false amend=false
  for arg in "$@"; do
    [ "$arg" = "--no-push" ] && no_push=true
    [ "$arg" = "--amend" ] && amend=true
  done
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "вқҢ д»»еҠЎ $name дёҚеӯҳеңЁ"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "вҡ пёҸ  $label worktree дёҚеӯҳеңЁпјҢи·іиҝҮ"; continue; }
    local has_changes
    has_changes=$(cd "$wd" && git status --porcelain 2>/dev/null | head -1)
    [ -z "$has_changes" ] && { echo "в„№пёҸ  $label ж— ж”№еҠЁпјҢи·іиҝҮ"; continue; }
    local amend_flag=""
    $amend && amend_flag="--amend"
    (cd "$wd" && git add . && git commit ${amend_flag:+"$amend_flag"} -m "$msg") 2>&1 | sed "s/^/   $label: /"
    if ! $no_push; then
      (cd "$wd" && git push origin "$(git rev-parse --abbrev-ref HEAD)") 2>&1 \
        | sed "s/^/   $label push: /" || echo "вҡ пёҸ  $label push еӨұиҙҘ"
    fi
  done
  echo "вң… жҸҗдәӨе®ҢжҲҗ"
}

cmd_rebase() {
  local name=$1
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "вқҢ д»»еҠЎ $name дёҚеӯҳеңЁ"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "вҡ пёҸ  $label worktree дёҚеӯҳеңЁпјҢи·іиҝҮ"; continue; }
    local base
    base=$(base_branch "$repo")
    (cd "$wd" \
      && git stash push -m "wt-auto-$(date +%s)" 2>/dev/null || true \
      && git fetch origin 2>&1 \
      && git rebase "origin/$base" 2>&1 \
      && git stash pop 2>/dev/null || true) | sed "s/^/   $label: /" || {
        echo "вқҢ $label rebase еҶІзӘҒпјҢиҜ·жүӢеҠЁеӨ„зҗҶ"; exit 1
      }
  done
  echo "вң… rebase е®ҢжҲҗ"
}

cmd_cleanup() {
  local name=$1; shift
  local force=false
  for arg in "$@"; do [ "$arg" = "--force" ] && force=true; done
  resolve_project
  local dir
  dir=$(worktree_path "$name")
  [ -d "$dir" ] || { echo "вқҢ д»»еҠЎ $name дёҚеӯҳеңЁ"; exit 1; }
  for entry in "${REPOS[@]}"; do
    local label repo
    label="${entry%%	*}"
    repo="${entry#*	}"
    local wd="$dir/$label"
    [ ! -d "$wd" ] && { echo "вҡ пёҸ  $label worktree дёҚеӯҳеңЁпјҢи·іиҝҮ"; continue; }
    if ! $force; then
      local branch
      branch=$(git -C "$wd" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
      local base
      base=$(base_branch "$repo")
      local merged
      merged=$(git -C "$repo" branch --merged "origin/$base" 2>/dev/null \
        | grep -q "^\*\| $branch$" && echo true || echo false)
      local pushed
      pushed=$(git -C "$wd" rev-list "origin/$branch..HEAD" --count 2>/dev/null || echo 1)
      [ "$merged" != "true" ] && { echo "вқҢ $label еҲҶж”ҜжңӘеҗҲе№¶пјҢз”Ё --force и·іиҝҮжЈҖжҹҘ"; exit 1; }
      [ "$pushed" -gt 0 ] && { echo "вқҢ $label жңүжңӘжҺЁйҖҒжҸҗдәӨпјҢз”Ё --force и·іиҝҮжЈҖжҹҘ"; exit 1; }
    fi
    git -C "$repo" worktree remove "$wd" 2>&1 | sed "s/^/   $label: /" || {
      echo "вҡ пёҸ  $label worktree remove еӨұиҙҘпјҢе°қиҜ• git branch -D"
      local branch
      branch=$(git -C "$wd" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
      [ -n "$branch" ] && git -C "$repo" branch -D "$branch" 2>/dev/null || true
    }
  done
  rm -f "$dir/CONTEXT.md"
  rmdir "$dir" 2>/dev/null || echo "вҡ пёҸ  зӣ®еҪ• $dir жңӘе®Ңе…Ёжё…з©әпјҢиҜ·жүӢеҠЁжЈҖжҹҘ"
  echo "вң… жё…зҗҶе®ҢжҲҗ"
}

cmd_doctor() {
  local root="$WT_ROOT"
  [ -d "$root" ] || { echo "вң… ж— ж®Ӣз•ҷд»»еҠЎ"; return; }
  local found=false
  for pdir in "$root"/*/; do
    [ ! -d "$pdir" ] && continue
    local project
    project="$(basename "$pdir")"
    for tdir in "$pdir"/*/; do
      [ ! -d "$tdir" ] && continue
      local name
      name="$(basename "$tdir")"
      local issues=()
      [ ! -f "$tdir/CONTEXT.md" ] && issues+=("зјә CONTEXT.md")
      if [ ${#issues[@]} -gt 0 ]; then
        found=true
        echo "в”Җв”Җв”Җ $project / $name в”Җв”Җв”Җ"
        for i in "${issues[@]}"; do echo "   вҡ пёҸ  $i"; done
      fi
    done
  done
  $found || echo "вң… ж— ејӮеёё"
}

cmd_update() {
  local self
  self=$(type -p wt 2>/dev/null || echo "$0")
  if [ -L "$self" ]; then
    local link_target="$self"
    local link_parent
    while [ -L "$link_target" ]; do
      link_parent=$(dirname "$link_target")
      link_target=$(readlink "$link_target" 2>/dev/null || true)
      [ -z "$link_target" ] && break
      case "$link_target" in
        /*) ;;
        *) link_target="$link_parent/$link_target" ;;
      esac
    done
    if echo "$link_target" | grep -q node_modules; then
      echo "вқҢ йҖҡиҝҮ npm е®үиЈ…пјҢиҜ·з”Ё npm update -g wt-multi-repo жӣҙж–°" >&2
      exit 1
    fi
  fi
  local target="$self"
  local latest tag url
  # GitHub дјҳе…Ҳ
  latest=$(git ls-remote --tags https://github.com/douxt/wt.git 2>/dev/null \
    | sed 's/.*refs\/tags\///' | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | tail -1 || true)
  if [ -n "$latest" ]; then
    tag="$latest"
    url="https://raw.githubusercontent.com/douxt/wt/${tag}/wt"
  fi
  # Gitee еӣһйҖҖ
  if [ -z "$latest" ]; then
    latest=$(git ls-remote --tags https://gitee.com/cybxcoder/wt.git 2>/dev/null \
      | sed 's/.*refs\/tags\///' | grep -E '^v[0-9]+\.[0-9]+\.[0-9]+$' | tail -1 || true)
    [ -n "$latest" ] && tag="$latest" && url="https://gitee.com/cybxcoder/wt/raw/${tag}/wt"
  fi
  tag="${tag:-master}"
  url="${url:-https://raw.githubusercontent.com/douxt/wt/master/wt}"
  curl -fsSL "$url" -o "$target.tmp" && chmod +x "$target.tmp" && mv "$target.tmp" "$target"
  echo "вң… wt е·Іжӣҙж–°еҲ° ${tag}"
}

# в”Җв”Җ Dispatch в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
usage() {
  echo "з”Ёжі•: wt [-p <йЎ№зӣ®зӣ®еҪ•>] <е‘Ҫд»Ө> [еҸӮж•°]"
  echo ""
  echo "е‘Ҫд»Ө:"
  echo "  create <name> [-m <жҸҸиҝ°>]   еҲӣе»әи·Ёд»“еә“ worktree"
  echo "  list                         еҲ—еҮәжҙ»и·ғд»»еҠЎ"
  echo "  status <name>                жҹҘзңӢд»“еә“зҠ¶жҖҒ"
  echo "  commit <name> <msg> [йҖүйЎ№]   жҸҗдәӨ+жҺЁйҖҒ"
  echo "                               йҖүйЎ№: --no-push, --amend"
  echo "  rebase <name>                д»“еә“ rebase дё»еҲҶж”Ҝ"
  echo "  cleanup <name> [--force]     жё…зҗҶ worktree"
  echo "  doctor                       жЈҖжҹҘж®Ӣз•ҷ worktree"
  echo "  update                       жӣҙж–° wt еҲ°жңҖж–°зүҲ"
  echo ""
  echo "зӨәдҫӢ:"
  echo "  cd ~/projects/UMES3 && wt create fix-login"
  echo "  wt -p ~/projects/CeLiangBen status fix-order"
}

load_config

# Parse -p global option
PROJECT_FLAG=""
if [ $# -ge 2 ] && [ "$1" = "-p" ]; then
  PROJECT_FLAG="$2"
  shift 2
fi

[ "${1:-}" = "--version" ] && { echo "wt $VERSION"; exit 0; }
[ $# -lt 1 ] && { usage; exit 1; }

case "${1:-}" in
  create)
    name="${2:-}"; [ -z "$name" ] && { echo "йңҖиҰҒд»»еҠЎеҗҚ"; exit 1; }
    desc=""; [ "${3:-}" = "-m" ] && desc="${4:-}"
    cmd_create "$name" "$desc"
    ;;
  list) cmd_list ;;
  status)
    name="${2:-}"; [ -z "$name" ] && { echo "йңҖиҰҒд»»еҠЎеҗҚ"; exit 1; }
    cmd_status "$name"
    ;;
  commit)
    name="${2:-}"; msg="${3:-}"
    [ -z "$name" ] && { echo "йңҖиҰҒд»»еҠЎеҗҚ"; exit 1; }
    [ -z "$msg" ] && { echo "йңҖиҰҒжҸҗдәӨдҝЎжҒҜ"; exit 1; }
    shift 3; cmd_commit "$name" "$msg" "$@"
    ;;
  rebase)
    name="${2:-}"; [ -z "$name" ] && { echo "йңҖиҰҒд»»еҠЎеҗҚ"; exit 1; }
    cmd_rebase "$name"
    ;;
  cleanup)
    name="${2:-}"; [ -z "$name" ] && { echo "йңҖиҰҒд»»еҠЎеҗҚ"; exit 1; }
    shift 2; cmd_cleanup "$name" "$@"
    ;;
  doctor) cmd_doctor ;;
  update) cmd_update ;;
  *) usage; exit 1 ;;
esac
